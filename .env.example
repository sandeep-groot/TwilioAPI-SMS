# Twilio credentials (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token

# Your Twilio phone number in E.164 format (for API sync fallback)
TWILIO_PHONE_NUMBER=+16184143472

# Public SMS webhook URL — must match Twilio console exactly (no trailing slash)
TWILIO_WEBHOOK_URL=https://your-public-url.ngrok-free.dev/webhook/sms

# Public voice webhook URL (optional — derived from TWILIO_WEBHOOK_URL if omitted)
TWILIO_VOICE_WEBHOOK_URL=https://your-public-url.ngrok-free.dev/webhook/voice

# Spoken when answering inbound calls
TWILIO_VOICE_GREETING=Thank you for calling. Please leave a message after the beep.

# Record voicemail after greeting (true/false)
TWILIO_VOICE_RECORD=true

# Server
HOST=0.0.0.0
PORT=8000
